{
  "name": "nba_alpha_agent",
  "version": "1.0.0",
  "description": "NBA Alpha Agent - Automatic Arbitrage Simulation System",
  "entry_point": "main.py",
  "triggers": {
    "schedule": [
      {
        "cron": "0 10 * * *",
        "action": "daily_setup_and_execution",
        "timezone": "America/New_York",
        "description": "Daily initialization, data aggregation and simulation trading"
      },
      {
        "cron": "0 2 * * *",
        "action": "settlement_job",
        "timezone": "America/New_York",
        "description": "Daily settlement of pending trades"
      }
    ]
  }
}
